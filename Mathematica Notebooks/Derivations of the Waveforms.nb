Cell[TextData[{
 "Given the chirp mass, we can plot the total mass as a function of the mass \
ratios. Since there are two independent mass ratios (note that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Beta]", "3"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta_3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c60ab56-a53b-419c-be14-fd9db2418f31"],
 " can be eliminated using ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Beta]", "3"], "\[LongEqual]", "1", "-", 
         SubscriptBox["\[Beta]", "1"], "-", 
         SubscriptBox["\[Beta]", "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta_3 = 1 - \\beta_1 - \\beta_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "fe2d92a5-880c-4910-a07a-e227c839885e"],
 "), we expect the plot to be a surface."
}], "Text",
 CellChangeTimes->{{3.9802152606712914`*^9, 
  3.98021532554121*^9}},ExpressionUUID->"3b40d622-3250-4b83-9aee-\
ada72f617e39"],

