    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b6f5ad63-570e-4dc3-a031-4d6284b59733"],
 " (using also ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Beta]", "1"], "+", 
         SubscriptBox["\[Beta]", "2"], "+", 
         SubscriptBox["\[Beta]", "3"], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta_1 + \\beta_2 + \\beta_3 = 1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ae84a079-2810-404c-9381-f5ce2407fc46"],
 "), we have"
}], "Text",
