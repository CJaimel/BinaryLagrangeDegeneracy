Cell[TextData[{
 "Since ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Beta]", "1"], "+", 
         SubscriptBox["\[Beta]", "2"], "+", 
         SubscriptBox["\[Beta]", "3"], "\[LongEqual]", "1"}], 
       TraditionalForm], "errors" -> {}, "input" -> 
     "\\beta_1 + \\beta_2 + \\beta_3 = 1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d17a1015-492e-4133-9c64-90d808c49819"],
 ", then the difference is zero; hence, the two terms are equal. Next, for \
the term oscillating at ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"3", "\[Omega]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "3\\omega", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2efd1aed-6bb3-49ea-9c5f-89fbef071615"],
 ", we have"
}], "Text",
 CellChangeTimes->{{3.975961437877782*^9, 
  3.975961501338578*^9}},ExpressionUUID->"c495c96c-3264-4074-be82-\
d3dc6903dcf6"],

