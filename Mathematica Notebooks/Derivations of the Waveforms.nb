Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Nu]", "1"], "+", 
         SubscriptBox["\[Nu]", "2"], "+", 
         SubscriptBox["\[Nu]", "3"], "\[LongEqual]", "1"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\nu_1 + \\nu_2 + \\nu_3 = 1", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "07594890-c79d-4fae-9126-e961f448ca94"],
 ". In the limit where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Nu]", "3"], "\[LongEqual]", "0"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\nu_3 = 0", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "51fccb64-c0a3-4430-bfd0-de9a5cdb8f7c"],
 ", we obtain the expression for the total orbital energy of a binary \
system."
}], "Text",
 CellChangeTimes->{{3.961966940039112*^9, 
  3.961967015432583*^9}},ExpressionUUID->"cb4b16c4-d4e9-495a-8013-\
9271db08e63d"],

