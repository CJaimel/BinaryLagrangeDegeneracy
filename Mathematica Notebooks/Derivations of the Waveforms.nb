Cell[TextData[{
 "First, we will determine an orthonormal set of unit vectors in the rotated \
frame. An immediate choice would be rotating the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       OverscriptBox[
        StyleBox["y", "TI"], "^"], TraditionalForm], "errors" -> {}, "input" -> 
     "\\hat{y}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "8b340586-1bc3-4b9f-b930-0054ebda5167"],
 " unit vector by an angle of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Iota]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\iota", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b0223757-d1b8-40ed-90d9-beacd31f8584"],
 " about the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["x", "TI"], TraditionalForm], "errors" -> {}, "input" -> "x", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "7462b5a4-8740-4e5b-8ae3-eef981b3f4a6"],
 "-axis."
}], "Text",
