Cell[TextData[{
 "The traceless tensors ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["E", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["j", "TI"]}], "+"], TraditionalForm], "errors" -> {}, 
     "input" -> "E_{ij}^{+}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "86494168-f0db-45b1-9007-e6d80906eaae"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubsuperscriptBox[
        StyleBox["E", "TI"], 
        RowBox[{
          StyleBox["i", "TI"], 
          StyleBox["j", "TI"]}], "\[Cross]"], TraditionalForm], 
     "errors" -> {}, "input" -> "E_{ij}^{\\times}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5dac5073-0a18-4f51-a6ca-948366cc573b"],
 " that are transverse to the unit vector pointing to the observer are as \
follows."
}], "Text",
