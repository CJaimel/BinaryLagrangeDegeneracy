Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["M", "total"], "[", 
    RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
   RowBox[{"8", 
    SuperscriptBox[
     RowBox[{"(", 
      FractionBox[
       RowBox[{
        RowBox[{"x", " ", "y"}], "+", 
        RowBox[{"x", 
