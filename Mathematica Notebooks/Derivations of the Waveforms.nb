Cell["\<\
Hence, the two expressions are equivalent. The total orbital energy of the \
system in terms of the mass ratios is\
\>", "Text",
 CellChangeTimes->{{3.9619029712039843`*^9, 3.961902998065589*^9}, {
  3.974668317752799*^9, 
  3.974668322755061*^9}},ExpressionUUID->"f74461a5-1727-4677-895b-\
26873949b6cb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], "\[Times]", 
      FractionBox[
       SuperscriptBox["M", "2"], "a"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[Beta]", "1"], 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            SubscriptBox["\[Beta]", "2"], "2"], "+", 
           RowBox[{
            SubscriptBox["\[Beta]", "2"], 
            SubscriptBox["\[Beta]", "3"]}], "+", 
           SuperscriptBox[
            SubscriptBox["\[Beta]", "3"], "2"]}], ")"}]}], "+", 
        RowBox[{
         SubscriptBox["\[Beta]", "2"], 
         RowBox[{"(", 
          RowBox[{
           SuperscriptBox[
            SubscriptBox["\[Beta]", "1"], "2"], "+", 
