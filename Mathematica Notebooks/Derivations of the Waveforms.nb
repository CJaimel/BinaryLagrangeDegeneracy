Cell[CellGroupData[{

Cell["Current Quadrupole", "Subsubsection",
 CellChangeTimes->{{3.975789989355463*^9, 
  3.9757899928092937`*^9}},ExpressionUUID->"0b17d1b4-3bc4-49ba-b2e3-\
c070b0cf4132"],

Cell[TextData[{
 "The current quadrupole is given by ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["Z", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"]}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], 
            StyleBox["k", "TI"]}]], "+", 
         SuperscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["i", "TI"], 
            StyleBox["k", "TI"]}]], "-", "2", 
         SuperscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["k", "TI"], 
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "Z^{ijk} = P^{ijk} + P^{jik} - 2P^{kij}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "3cd44a17-035b-408f-a670-15cc480c05cd"],
 ". We choose the observer to lie along the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["z", "TI"], TraditionalForm], "errors" -> {}, "input" -> "z", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "bb4112bb-3f6d-45dc-b58a-de0f15002a64"],
 "-axis of the COM frame so that the trajectory of the ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       StyleBox["p", "TI"], TraditionalForm], "errors" -> {}, "input" -> "p", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "89554513-ba73-4cd2-aaff-e4eaa9976353"],
 "th mass is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["x", "TI"], 
          StyleBox["p", "TI"]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["X", "TI"], 
          StyleBox["p", "TI"]], "cos", 
         RowBox[{"(", 
           RowBox[{"\[Omega]", 
             StyleBox["t", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "x_p = X_p \\cos(\\omega t)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b38ec427-cb20-4ea6-b8fb-cc73fce3977d"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["y", "TI"], 
          StyleBox["p", "TI"]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["X", "TI"], 
          StyleBox["p", "TI"]], "cos", 
         RowBox[{"(", "\[Iota]", ")"}], "sin", 
         RowBox[{"(", 
           RowBox[{"\[Omega]", 
             StyleBox["t", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "y_p = X_p \\cos(\\iota) \\sin(\\omega t)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "e6a669a5-ba05-4ffd-915f-28419017b97f"],
 ", and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["z", "TI"], 
          StyleBox["p", "TI"]], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["X", "TI"], 
          StyleBox["p", "TI"]], "sin", 
         RowBox[{"(", "\[Iota]", ")"}], "sin", 
         RowBox[{"(", 
           RowBox[{"\[Omega]", 
             StyleBox["t", "TI"]}], ")"}]}], TraditionalForm], "errors" -> {},
      "input" -> "z_p = X_p \\sin(\\iota) \\sin(\\omega t)", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "4a5373db-3a43-4e43-8fc8-6567ddaa6e0f"],
 ". Since ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["n", "TI"], 
          StyleBox["i", "TI"]], "\[LongEqual]", 
         RowBox[{"(", 
           RowBox[{"0", ",", "0", ",", "1"}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> "n^i = (0, 0, 1)", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "43dc3a66-8bb7-4cd7-8c7e-53de2ef66a24"],
 ", then we only need ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SuperscriptBox[
          StyleBox["Z", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], "3"}]], "\[LongEqual]", 
         SuperscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"], "3"}]], "+", 
         SuperscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{
            StyleBox["j", "TI"], 
            StyleBox["i", "TI"], "3"}]], "-", "2", 
         SuperscriptBox[
          StyleBox["P", "TI"], 
          RowBox[{"3", 
            StyleBox["i", "TI"], 
            StyleBox["j", "TI"]}]]}], TraditionalForm], "errors" -> {}, 
     "input" -> "Z^{ij3} =  P^{ij3} + P^{ji3} - 2P^{3ij}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "033e1ef0-2048-4b8a-a20e-029a12c91e10"],
 ". Using this, the plus polarization of the current quadrupole results to"
}], "Text",
 CellChangeTimes->{{3.9757899955191593`*^9, 3.975790000872674*^9}, {
  3.975959113487335*^9, 3.975959118304655*^9}, {3.9759591675109797`*^9, 
