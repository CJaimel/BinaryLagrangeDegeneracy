             RowBox[{"1", "-", "x", "-", "y"}], ")"}]}]}], ")"}], "2"], "-", 
        RowBox[{"3", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SuperscriptBox["x", "2"], "y", 
            RowBox[{"(", 
             RowBox[{"1", "-", "x", "-", "y"}], ")"}]}], "+", 
           RowBox[{"x", " ", 
            SuperscriptBox["y", "2"], 
            RowBox[{"(", 
             RowBox[{"1", "-", "x", "-", "y"}], ")"}]}], "+", 
           RowBox[{"x", " ", "y", 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"1", "-", "x", "-", "y"}], ")"}], "2"]}]}], ")"}]}]}]], 
      ")"}], 
