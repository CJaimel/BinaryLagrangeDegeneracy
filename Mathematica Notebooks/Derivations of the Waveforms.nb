      SubsuperscriptBox["X", "p", "3"]}], "+", 
     RowBox[{"7", " ", 
      SuperscriptBox["\[Omega]", "3"], " ", 
      RowBox[{"Cos", "[", "\[Iota]", "]"}], " ", 
      RowBox[{"Sin", "[", "\[Iota]", "]"}], " ", 
      RowBox[{"TrigReduce", "[", 
       SuperscriptBox[
        RowBox[{"Sin", "[", 
         RowBox[{
          RowBox[{"t", " ", "\[Omega]"}], "+", "\[Phi]", "+", 
          SubscriptBox["\[Theta]", "p"]}], "]"}], "3"], "]"}], " ", 
      SubscriptBox["m", "p"], " ", 
      SubsuperscriptBox["X", "p", "3"]}]}], ")"}]}], "//", 
  "Factor"}]], "Input",
