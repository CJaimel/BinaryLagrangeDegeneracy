 CellLabel->"Out[40]=",ExpressionUUID->"9425501d-e6ce-4d71-b986-7e08103db361"]
}, Open  ]],

Cell[BoxData[
 RowBox[{
  RowBox[{"F", "[", 
   RowBox[{"\[Alpha]_", ",", "\[Beta]_"}], "]"}], ":=", 
  SqrtBox[
   FractionBox[
    RowBox[{
     RowBox[{"3", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Alpha]", "+", "\[Beta]"}], ")"}], "2"], 
      " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          SuperscriptBox["\[Alpha]", "2"]}], "+", 
         RowBox[{"\[Alpha]", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"2", " ", "\[Beta]"}]}], ")"}]}], "+", 
         RowBox[{"\[Beta]", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            RowBox[{"2", " ", "\[Beta]"}]}], ")"}]}]}], ")"}], "2"]}], "+", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Alpha]", "-", 
        RowBox[{"3", " ", 
         SuperscriptBox["\[Alpha]", "2"]}], "+", 
        RowBox[{"2", " ", 
         SuperscriptBox["\[Alpha]", "3"]}], "+", 
        RowBox[{"\[Beta]", " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1"}], "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"3", "-", 
              RowBox[{"2", " ", "\[Beta]"}]}], ")"}], " ", "\[Beta]"}]}], 
          ")"}]}]}], ")"}], "2"]}], 
    RowBox[{
     RowBox[{"27", " ", 
      SuperscriptBox["\[Alpha]", "2"], " ", 
      SuperscriptBox["\[Beta]", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Alpha]", "+", "\[Beta]"}], ")"}], "2"]}],
      "+", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"\[Alpha]", "-", "\[Beta]"}], ")"}], "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         RowBox[{"2", " ", "\[Alpha]"}], "+", "\[Beta]"}], ")"}], "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", "\[Alpha]", "+", 
         RowBox[{"2", " ", "\[Beta]"}]}], ")"}], "2"]}]}]]]}]], "Input",
 CellChangeTimes->{
  3.9676284307251472`*^9, {3.967628503057807*^9, 3.967628566007571*^9}, {
   3.9693072323133583`*^9, 3.969307232522808*^9}},
 CellLabel->"In[41]:=",ExpressionUUID->"b1e5d98f-9b49-40ba-ab8c-eb9496e40547"],

Cell[TextData[{
 "By plotting this relation, we obtain a surface that characterizes the \
nature of the triple system that emits a waveform identical to that of a \
binary system characterized by the ratio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       FractionBox[
        SubscriptBox[
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["A", "TI"], "+"], ")"}], "\[Omega]"], 
        SubscriptBox[
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["A", "TI"], "+"], ")"}], 
         RowBox[{"3", "\[Omega]"}]]], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\frac{(\\mathcal{A}^+)_{\\omega}}{(\\mathcal{A}^+)_{3\\omega}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5d54ebc8-5d7e-4715-96fd-11b2865dcfd6"],
 ". Note that for any binary system, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["3", "9"], "\[LessEqual]", 
         FractionBox[
          SubscriptBox[
           RowBox[{"(", 
             SuperscriptBox[
              StyleBox["A", "TI"], "+"], ")"}], "\[Omega]"], 
          SubscriptBox[
           RowBox[{"(", 
             SuperscriptBox[
              StyleBox["A", "TI"], "+"], ")"}], 
           RowBox[{"3", "\[Omega]"}]]], "\[LessEqual]", 
         FractionBox["5", "9"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{3}{9} \\le \
\\frac{(\\mathcal{A}^+)_{\\omega}}{(\\mathcal{A}^+)_{3\\omega}} \\le \
\\frac{5}{9}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "23ef1fdc-1272-453a-94d0-014d2e17aebd"],
 "."
}], "Text",
 CellChangeTimes->{{3.967619193697927*^9, 3.9676192485516033`*^9}, {
  3.9676193001783237`*^9, 3.9676193043554907`*^9}, {3.967619356147582*^9, 
  3.967619381631693*^9}},ExpressionUUID->"1e18b081-094b-4ddf-9751-\
b43107d00c0c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"ConditionalExpression", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ArcSin", "[", 
       SqrtBox[
        RowBox[{"2", "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            FractionBox["1", "4"], "-", 
            RowBox[{
             FractionBox["9", "2"], 
             RowBox[{"(", "0.365", ")"}], 
             FractionBox["1", 
              SqrtBox[
               FractionBox[
                RowBox[{
                 RowBox[{"3", " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    SubscriptBox["\[Beta]", "1"], "+", 
                    SubscriptBox["\[Beta]", "2"]}], ")"}], "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", " ", 
                    SubsuperscriptBox["\[Beta]", "1", "2"]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "1"], " ", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}]}]}], ")"}], 
                   "2"]}], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["\[Beta]", "1"], "-", 
                    RowBox[{"3", " ", 
                    SubsuperscriptBox["\[Beta]", "1", "2"]}], "+", 
                    RowBox[{"2", " ", 
                    SubsuperscriptBox["\[Beta]", "1", "3"]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"3", "-", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}], " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}]}]}], ")"}], 
                  "2"]}], 
                RowBox[{
                 RowBox[{"27", " ", 
                  SubsuperscriptBox["\[Beta]", "1", "2"], " ", 
                  SubsuperscriptBox["\[Beta]", "2", "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    SubscriptBox["\[Beta]", "1"], "+", 
                    SubscriptBox["\[Beta]", "2"]}], ")"}], "2"]}], "+", 
                 RowBox[{
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "1"], "-", 
                    SubscriptBox["\[Beta]", "2"]}], ")"}], "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "1"]}], "+", 
                    SubscriptBox["\[Beta]", "2"]}], ")"}], "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    SubscriptBox["\[Beta]", "1"], "+", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}], "2"]}]}]]]]}]}], 
           ")"}], 
          RowBox[{"-", "1"}]]}]], "]"}], "\[Times]", 
      FractionBox["180", "\[Pi]"]}], ",", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[Beta]", "1"], "+", 
       SubscriptBox["\[Beta]", "2"]}], "<=", "1"}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Beta]", "1"], ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Beta]", "2"], ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)\>\"", ",", 
      "\"\<\!\(\*SubscriptBox[\(\[Beta]\), \(2\)]\)\>\"", ",", 
      "\"\<\!\(\*SubscriptBox[\(\[Iota]\), \((3  B)\)]\)\>\""}], "}"}]}]}], 
  "]"}]], "Input",
 CellChangeTimes->{{3.9677716487778997`*^9, 3.967771706034644*^9}, {
  3.9677717613843803`*^9, 3.9677718137921658`*^9}},
 CellLabel->"In[42]:=",ExpressionUUID->"a8f3933d-bf65-4b42-97ad-63ad1cebacc7"],

