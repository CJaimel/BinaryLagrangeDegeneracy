Cell[BoxData[{
 RowBox[{
  RowBox[{"eq1", "=", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], 
     SubscriptBox["\[Beta]", "3"], 
     RowBox[{"(", 
      RowBox[{
