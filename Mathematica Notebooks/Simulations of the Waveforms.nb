 FractionBox[
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["m", "1"], " ", 
     SubscriptBox["m", "2"]}], ")"}], 
   RowBox[{"3", "/", "5"}]], 
  SuperscriptBox[
   RowBox[{"(", 
    RowBox[{
     SubscriptBox["m", "1"], "+", 
     SubscriptBox["m", "2"]}], ")"}], 
   RowBox[{"1", "/", "5"}]]]], "Output",
