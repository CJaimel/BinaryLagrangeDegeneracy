Cell[TextData[{
 "Without radiation reaction, the phase of the two systems will be identical \
when two of the masses in the triple system are equal. In this case, the \
chirp mass of the triple system sets a lower bound on the total mass. As an \
example, consider a Lagrange three-body system with parameters ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["m", "TI"], "1"], "\[LongEqual]", 
         SubscriptBox[
          StyleBox["m", "TI"], "2"], "\[LongEqual]", "1.5"}], 
       TraditionalForm], "errors" -> {}, "input" -> "m_1 = m_2 = 1.5", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "28da0e72-6398-46b3-85ff-047f3311e66d"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["m", "TI"], "3"], "\[LongEqual]", "3"}], TraditionalForm], 
     "errors" -> {}, "input" -> "m_3 = 3", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "09868cf8-8199-4054-914c-8227a9c4930c"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["l", "TI"], "\[LongEqual]", "195"}], TraditionalForm], 
     "errors" -> {}, "input" -> "l = 195", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "202b1406-4561-488e-af96-622efd90464a"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"\[Iota]", "\[LongEqual]", "31"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\iota = 31", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "ae313479-892b-4d7b-87b8-7c8d4c7739a0"],
 ", and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["r", "TI"], "\[LongEqual]", "184000"}], TraditionalForm], 
     "errors" -> {}, "input" -> "r = 184000", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "cdbce314-ab2d-4640-aa00-3bb7f2150153"],
 ". The chirp mass of this system is ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["M", "TI"], "\[TildeTilde]", "3.716"}], TraditionalForm], 
     "errors" -> {}, "input" -> "\\mathcal{M} \\approx 3.716", "state" -> 
     "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "98caebcb-32e8-4bf0-8238-d13ced51f912"],
 "."
}], "Text",
 CellChangeTimes->{{3.9623134272258167`*^9, 3.962313458036018*^9}, {
  3.962313488073324*^9, 3.962313515923464*^9}, {3.962409804148409*^9, 
  3.962409846497817*^9}},ExpressionUUID->"2adddedd-e578-4396-bfc5-\
16bacbdc266a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   SubscriptBox["M", "chirp"], "[", 
   RowBox[{
    SubscriptBox["m", "1"], ",", 
    SubscriptBox["m", "2"], ",", "0"}], "]"}], "//", "Simplify"}]], "Input",
 CellChangeTimes->{{3.962945180612731*^9, 3.962945199303673*^9}, {
  3.9629453168080683`*^9, 3.962945353334591*^9}, {3.962945624712962*^9, 
