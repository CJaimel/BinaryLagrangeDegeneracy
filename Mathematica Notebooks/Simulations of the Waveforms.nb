   3.980055570521144*^9},
 CellLabel->"Out[51]=",ExpressionUUID->"5f5fe346-7253-44ae-adad-b2ac61553b04"]
}, Open  ]],

Cell[TextData[{
 "Without imposing the equality of the chirp masses, the previous plot shows \
that the possible values of ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Beta]", "1"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d7b0a187-9678-4337-bbc5-795c670456f2"],
 " for degeneracy to occur lies around between 0.18 and 0.21. However, \
equality of the chirp masses implies that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Beta]", "1"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "49051f87-0993-4a25-8a55-2b38f85f1b86"],
 " must be greater than around 0.334. Thus, these two conditions for \
degeneracy cannot be both simultaneously satisfied."
}], "Text",
 CellChangeTimes->{{3.9704657520904703`*^9, 3.970465874083057*^9}, {
  3.970465905457321*^9, 
  3.970465951453733*^9}},ExpressionUUID->"939a270a-2fa0-4a00-9d08-\
0b52ebdaa7b8"],

Cell["\<\
Imposing the Newtonian stability condition, we have the following plot.\
\>", "Text",
 CellChangeTimes->{{3.9693084559266243`*^9, 
  3.969308465540565*^9}},ExpressionUUID->"28bc0e8c-9a17-4bac-84da-\
aabd9b0aeeef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"RegionPlot", "[", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["\[Beta]", "1"], 
       SubscriptBox["\[Beta]", "2"]}], "+", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["\[Beta]", "1"], "+", 
         SubscriptBox["\[Beta]", "2"]}], ")"}], 
       RowBox[{"(", 
        RowBox[{"1", "-", 
         SubscriptBox["\[Beta]", "1"], "-", 
         SubscriptBox["\[Beta]", "2"]}], ")"}]}]}], "<", 
     FractionBox["1", "27"]}], "&&", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Beta]", "1"], "+", 
      SubscriptBox["\[Beta]", "2"]}], "<=", "1"}]}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Beta]", "1"], ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Beta]", "2"], ",", "0", ",", "1"}], "}"}]}], 
  "]"}]], "Input",
