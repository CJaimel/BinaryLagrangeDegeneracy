                 RowBox[{"3", "/", "2"}]]], ")"}], " ", "t"}], "-", 
             RowBox[{"3", "\[Phi]"}]}], "]"}]}]}], ")"}]}], "-", 
       RowBox[{"3", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           FractionBox[
            SqrtBox["3"], "2"], 
           FractionBox["\[Alpha]", 
