                    SubscriptBox["\[Beta]", "2"]}]}], ")"}], " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}]}]}], ")"}], 
                  "2"]}], 
                RowBox[{
                 RowBox[{"27", " ", 
                  SubsuperscriptBox["\[Beta]", "1", "2"], " ", 
