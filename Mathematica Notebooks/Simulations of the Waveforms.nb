    RowBox[{
     RowBox[{"-", 
      FractionBox["1", 
       RowBox[{"4", " ", "r"}]]}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], "2"], 
