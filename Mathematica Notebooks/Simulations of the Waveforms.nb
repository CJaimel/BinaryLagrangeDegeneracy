        RowBox[{
         SubscriptBox["\[CapitalPsi]", "quad"], "[", 
         RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "]"}], "-", 
        "\[Phi]"}], "]"}]}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"mass", " ", "octupole"}], " ", "+", " ", 
     RowBox[{
     "current", " ", "quadrupole", " ", "times", " ", "without", " ", 
      "radiation", " ", "reaction"}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SubscriptBox["h", "octcqPlus"], "[", 
     RowBox[{
     "l_", ",", "\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_", ",", "r_", 
      ",", "\[Iota]_", ",", "t_", ",", "\[Phi]_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", 
       RowBox[{"4", " ", "r"}]]}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], "2"], 
     RowBox[{"(", 
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
        RowBox[{"1", "/", "2"}]], 
       SuperscriptBox["l", 
        RowBox[{"3", "/", "2"}]]], ")"}], " ", 
     RowBox[{"Sin", "[", "\[Iota]", "]"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"9", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          SuperscriptBox[
           RowBox[{"Cos", "[", "\[Iota]", "]"}], "2"]}], ")"}], 
        FractionBox[
         SqrtBox[
          RowBox[{
           RowBox[{"27", 
            SuperscriptBox["\[Alpha]", "2"], 
            SuperscriptBox["\[Beta]", "2"], 
            SuperscriptBox["\[Gamma]", "2"]}], "+", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[Alpha]", "-", "\[Beta]"}], ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[Beta]", "-", "\[Gamma]"}], ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
