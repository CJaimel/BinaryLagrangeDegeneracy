Cell[TextData[{
 "By plotting this relation, we obtain a surface that characterizes the \
nature of the triple system that emits a waveform identical to that of a \
binary system characterized by the ratio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       FractionBox[
        SubscriptBox[
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["A", "TI"], "+"], ")"}], "\[Omega]"], 
        SubscriptBox[
         RowBox[{"(", 
           SuperscriptBox[
            StyleBox["A", "TI"], "+"], ")"}], 
         RowBox[{"3", "\[Omega]"}]]], TraditionalForm], "errors" -> {}, 
     "input" -> 
     "\\frac{(\\mathcal{A}^+)_{\\omega}}{(\\mathcal{A}^+)_{3\\omega}}", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5d54ebc8-5d7e-4715-96fd-11b2865dcfd6"],
 ". Note that for any binary system, ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox["3", "9"], "\[LessEqual]", 
         FractionBox[
          SubscriptBox[
           RowBox[{"(", 
             SuperscriptBox[
              StyleBox["A", "TI"], "+"], ")"}], "\[Omega]"], 
          SubscriptBox[
           RowBox[{"(", 
             SuperscriptBox[
              StyleBox["A", "TI"], "+"], ")"}], 
           RowBox[{"3", "\[Omega]"}]]], "\[LessEqual]", 
         FractionBox["5", "9"]}], TraditionalForm], "errors" -> {}, "input" -> 
     "\\frac{3}{9} \\le \
\\frac{(\\mathcal{A}^+)_{\\omega}}{(\\mathcal{A}^+)_{3\\omega}} \\le \
\\frac{5}{9}", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "23ef1fdc-1272-453a-94d0-014d2e17aebd"],
 "."
}], "Text",
 CellChangeTimes->{{3.967619193697927*^9, 3.9676192485516033`*^9}, {
  3.9676193001783237`*^9, 3.9676193043554907`*^9}, {3.967619356147582*^9, 
  3.967619381631693*^9}},ExpressionUUID->"1e18b081-094b-4ddf-9751-\
b43107d00c0c"],

