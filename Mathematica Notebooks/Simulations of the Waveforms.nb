        RowBox[{"3", "/", "2"}]]], ")"}], " ", 
     RowBox[{"Sin", "[", 
      RowBox[{"2", "\[Iota]"}], "]"}], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"9", 
        RowBox[{"(", 
