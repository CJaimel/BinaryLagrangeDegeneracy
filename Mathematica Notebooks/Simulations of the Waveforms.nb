   RowBox[{"MaxRecursion", "->", "0"}], ",", 
   RowBox[{"Exclusions", "->", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"m", "==", "0"}], ",", 
      RowBox[{"M", "==", "0"}], ",", 
      RowBox[{"M", "==", 
       RowBox[{"2", "m"}]}]}], "}"}]}], ",", 
