     RowBox[{
      FractionBox[
       RowBox[{"-", "2"}], "r"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
       RowBox[{"5", "/", "6"}]], 
      SuperscriptBox[
       RowBox[{
        SubscriptBox["M", "chirp"], "[", 
        RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "]"}], 
       RowBox[{"5", "/", "6"}]], 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
          RowBox[{"1", "/", "2"}]], 
