Cell["\<\
First, we define the functions for the chirp mass, initial phase, separation \
distance, and the frequency.\
\>", "Text",
 CellChangeTimes->{{3.962240071807411*^9, 
  3.962240095366234*^9}},ExpressionUUID->"bf857033-23e1-4f65-82e7-\
06e649209dab"],

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "quantities", " ", "derivable", " ", "from", " ", "the", " ", "source", 
    " ", "parameters"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"\[Alpha]", ",", " ", "\[Beta]", ",", " ", 
    RowBox[{
    "and", " ", "\[Gamma]", " ", "are", " ", "the", " ", "masses", " ", "of", 
     " ", "the", " ", "bodies", " ", "while", " ", "l", " ", "is", " ", "the",
      " ", "initial", " ", "separation", " ", "of", " ", "the", " ", 
     "masses"}]}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["M", "chirp"], "[", 
      RowBox[{"\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_"}], "]"}], ":=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
       RowBox[{
        RowBox[{"-", "1"}], "/", "5"}]], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         FractionBox["1", "2"], "\[Times]", 
         FractionBox[
          RowBox[{
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", "\[Alpha]", ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[Beta]", "-", "\[Gamma]"}], ")"}], "2"]}], "+", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", "\[Beta]", ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[Gamma]", "-", "\[Alpha]"}], ")"}], "2"]}], "+", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", "\[Gamma]", ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[Alpha]", "-", "\[Beta]"}], ")"}], "2"]}]}], 
          RowBox[{
           RowBox[{"\[Alpha]", " ", "\[Beta]"}], "+", 
           RowBox[{"\[Beta]", " ", "\[Gamma]"}], "+", 
           RowBox[{"\[Gamma]", " ", "\[Alpha]"}]}]]}], ")"}], 
       RowBox[{"3", "/", "5"}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalPsi]", "quad"], "[", 
      RowBox[{"\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_"}], "]"}], ":=", 
     RowBox[{"ArcTan", "[", 
      FractionBox[
       RowBox[{
        SqrtBox["3"], "\[Alpha]", 
        RowBox[{"(", 
         RowBox[{"\[Beta]", "-", "\[Gamma]"}], ")"}]}], 
       RowBox[{
        RowBox[{"\[Alpha]", 
         RowBox[{"(", 
          RowBox[{"\[Beta]", "+", "\[Gamma]"}], ")"}]}], "-", 
        RowBox[{"2", "\[Beta]", " ", "\[Gamma]"}]}]], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalPsi]", "1"], "[", 
      RowBox[{"\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_"}], "]"}], ":=", 
     RowBox[{"ArcTan", "[", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{
         RowBox[{"(", 
          RowBox[{"\[Beta]", "-", "\[Gamma]"}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            RowBox[{"(", 
             RowBox[{"\[Alpha]", "-", "\[Beta]"}], ")"}], 
            RowBox[{"(", 
             RowBox[{"\[Alpha]", "-", "\[Gamma]"}], ")"}]}], "-", 
           RowBox[{"3", "\[Beta]", " ", "\[Gamma]"}]}], ")"}]}], 
        RowBox[{
         SqrtBox["3"], "\[Alpha]", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"\[Beta]", 
            RowBox[{"(", 
             RowBox[{"\[Beta]", "-", "\[Alpha]"}], ")"}]}], "+", 
           RowBox[{"\[Gamma]", 
            RowBox[{"(", 
             RowBox[{"\[Gamma]", "-", "\[Alpha]"}], ")"}]}]}], ")"}]}]]}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[CapitalPsi]", "3"], "[", 
      RowBox[{"\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_"}], "]"}], ":=", 
     RowBox[{"ArcTan", "[", 
      FractionBox[
       RowBox[{
        RowBox[{"(", 
         RowBox[{"\[Alpha]", "-", "\[Beta]"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"\[Beta]", "-", "\[Gamma]"}], ")"}], 
        RowBox[{"(", 
         RowBox[{"\[Gamma]", "-", "\[Alpha]"}], ")"}]}], 
       RowBox[{"3", 
        SqrtBox["3"], "\[Alpha]", " ", "\[Beta]", " ", "\[Gamma]"}]], "]"}]}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"coal", "[", 
      RowBox[{"l_", ",", "\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_"}], 
      "]"}], ":=", 
     FractionBox[
      RowBox[{"5", 
       SuperscriptBox["l", "4"]}], 
      RowBox[{"256", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
        RowBox[{"4", "/", "3"}]], 
       SuperscriptBox[
        RowBox[{
         SubscriptBox["M", "chirp"], "[", 
         RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "]"}], 
        RowBox[{"5", "/", "3"}]]}]]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", 
      RowBox[{
      "l_", ",", "\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_", ",", "t_"}], 
      "]"}], ":=", 
     RowBox[{"l", 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         FractionBox["t", 
          RowBox[{"coal", "[", 
           RowBox[{"l", ",", "\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], 
           "]"}]]}], ")"}], 
       RowBox[{"1", "/", "4"}]]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[Omega]", "[", 
      RowBox[{
      "l_", ",", "\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_", ",", "t_"}], 
      "]"}], ":=", 
     RowBox[{
      FractionBox[
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
        RowBox[{"1", "/", "2"}]], 
       SuperscriptBox["l", 
        RowBox[{"3", "/", "2"}]]], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         FractionBox["t", 
          RowBox[{"coal", "[", 
           RowBox[{"l", ",", "\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], 
           "]"}]]}], ")"}], 
       RowBox[{
        RowBox[{"-", "3"}], "/", "8"}]]}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{{3.9611929297804537`*^9, 3.961193163553752*^9}, {
   3.9611933430094433`*^9, 3.9611935756794567`*^9}, {3.961193608636217*^9, 
