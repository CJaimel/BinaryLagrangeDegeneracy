Cell["\<\
We begin by checking the degeneracy at the quadrupole waveforms. In this \
case, \
\>", "Text",
 CellChangeTimes->{{3.970466098141242*^9, 
  3.970466113489747*^9}},ExpressionUUID->"4adf56fd-8546-498e-bbf4-\
0cfa1efee6a0"],

Cell[TextData[{
 "We can generate a surface that characterizes the degeneracy of the binary \
system and the triple system. For degeneracy to occur at the 0.5-PN level, \
the ratio of the amplitudes of the component sinusoids at ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|
    "boxes" -> FormBox["\[Omega]", TraditionalForm], "errors" -> {}, "input" -> 
     "\\omega", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "d6cc92fb-22ac-4c06-af0e-4cba7df72b0e"],
 " and ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{"3", "\[Omega]"}], TraditionalForm], "errors" -> {}, "input" -> 
     "3\\omega", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "f0ddb406-06f9-478a-8041-cb8f8fdb51a3"],
 " must obey the following relation ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         FractionBox[
          SubscriptBox[
           RowBox[{"(", 
             SuperscriptBox[
              StyleBox["A", "TI"], "+"], ")"}], "\[Omega]"], 
          SubscriptBox[
           RowBox[{"(", 
             SuperscriptBox[
              StyleBox["A", "TI"], "+"], ")"}], 
           RowBox[{"3", "\[Omega]"}]]], "\[LongEqual]", 
         FractionBox[
          RowBox[{"5", "+", "cos", 
            SuperscriptBox[
             RowBox[{"(", "\[Iota]", ")"}], "2"]}], 
          RowBox[{"18", 
            RowBox[{"[", 
              RowBox[{"1", "+", "cos", 
                SuperscriptBox[
                 RowBox[{"(", "\[Iota]", ")"}], "2"]}], "]"}]}]], 
         StyleBox["F", "TI"], 
         RowBox[{"(", 
           RowBox[{
             SubscriptBox["\[Beta]", "1"], ",", 
             SubscriptBox["\[Beta]", "2"]}], ")"}]}], TraditionalForm], 
     "errors" -> {}, "input" -> 
     "\\frac{(\\mathcal{A}^+)_{\\omega}}{(\\mathcal{A}^+)_{3\\omega}} = \
\\frac{5 + \\cos(\\iota)^2}{18[1 + \\cos(\\iota)^2]} F(\\beta_1, \\beta_2)", 
     "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "dd499f16-5703-4415-b3ef-854d1121ffaa"],
 ", where ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["F", "TI"], "(", 
         RowBox[{
           SubscriptBox["\[Beta]", "1"], ",", 
           SubscriptBox["\[Beta]", "2"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "F(\\beta_1, \\beta_2)", "state" -> "Boxes"|>,
    
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b37362ff-1238-42f9-a50f-8cd589bec388"],
 " is as follows:"
}], "Text",
 CellChangeTimes->{{3.9663737382898617`*^9, 3.966373751880862*^9}, 
   3.9663777548633003`*^9, {3.967618905978691*^9, 3.967619033473034*^9}, {
