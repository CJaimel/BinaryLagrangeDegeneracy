          RowBox[{"(", 
           RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
          "3"]], 
        RowBox[{"Cos", "[", 
         RowBox[{
          RowBox[{"3", 
           RowBox[{"(", 
            FractionBox[
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
              RowBox[{"1", "/", "2"}]], 
             SuperscriptBox["l", 
              RowBox[{"3", "/", "2"}]]], ")"}], "t"}], "-", 
          RowBox[{
           SubscriptBox["\[CapitalPsi]", "3"], "[", 
