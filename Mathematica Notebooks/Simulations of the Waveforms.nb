Cell[TextData[{
 "The Lagrange three-body system coalesces first when ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox[
          StyleBox["t", "TI"], 
          RowBox[{
            StyleBox["c", "TI"], ",", 
            StyleBox["(3B)", FontSlant -> "Plain"]}]], "<", 
         SubscriptBox[
          StyleBox["t", "TI"], 
          RowBox[{
            StyleBox["c", "TI"], ",", 
            StyleBox["(2B)", FontSlant -> "Plain"]}]]}], TraditionalForm], 
     "errors" -> {}, "input" -> "t_{c,\\mathrm{(3B)}} < t_{c,\\mathrm{(2B)}}",
      "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "34add48c-f9bd-4236-8bb7-9fdad106f581"],
 ". This simplifies to the following:"
}], "Text",
 CellChangeTimes->{{3.96863724812428*^9, 3.968637275509102*^9}, {
  3.968637306273138*^9, 
  3.9686373133024273`*^9}},ExpressionUUID->"42579a3f-3ef4-4859-93ba-\
fa631b9c670d"],

