Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"eq1", "=", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], 
     SubscriptBox["\[Beta]", "3"], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Beta]", "1"], "-", 
       SubscriptBox["\[Beta]", "2"]}], ")"}]}], 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Beta]", "3"], 
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Beta]", "1"], "+", 
        SubscriptBox["\[Beta]", "2"]}], ")"}]}], "-", 
     RowBox[{"2", 
      SubscriptBox["\[Beta]", "1"], 
      SubscriptBox["\[Beta]", "2"]}]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq2", "=", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SubscriptBox["\[Beta]", "1"], "-", 
        SubscriptBox["\[Beta]", "2"]}], ")"}], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Beta]", "3"], "-", 
           SubscriptBox["\[Beta]", "1"]}], ")"}], 
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Beta]", "3"], "-", 
           SubscriptBox["\[Beta]", "2"]}], ")"}]}], "-", 
        RowBox[{"3", 
         SubscriptBox["\[Beta]", "1"], 
         SubscriptBox["\[Beta]", "2"]}]}], ")"}]}], 
     RowBox[{
      SqrtBox["3"], 
      SubscriptBox["\[Beta]", "3"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[Beta]", "1"], 
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Beta]", "1"], "-", 
           SubscriptBox["\[Beta]", "3"]}], ")"}]}], "+", 
        RowBox[{
         SubscriptBox["\[Beta]", "2"], 
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Beta]", "2"], "-", 
           SubscriptBox["\[Beta]", "3"]}], ")"}]}]}], ")"}]}]]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"eq3", "=", 
   FractionBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Beta]", "1"], "-", 
       SubscriptBox["\[Beta]", "2"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Beta]", "2"], "-", 
       SubscriptBox["\[Beta]", "3"]}], ")"}], 
     RowBox[{"(", 
      RowBox[{
       SubscriptBox["\[Beta]", "3"], "-", 
       SubscriptBox["\[Beta]", "1"]}], ")"}]}], 
    RowBox[{"3", 
     SqrtBox["3"], 
     SubscriptBox["\[Beta]", "1"], 
     SubscriptBox["\[Beta]", "2"], 
     SubscriptBox["\[Beta]", "3"]}]]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Solve", "[", 
  RowBox[{
   RowBox[{
    RowBox[{"eq1", "==", "eq2"}], "&&", 
    RowBox[{"eq2", "==", "eq3"}]}], ",", 
   SubscriptBox["\[Beta]", "1"]}], "]"}]}], "Input",
 CellChangeTimes->{{3.9688939755420094`*^9, 3.968894087885778*^9}, {
