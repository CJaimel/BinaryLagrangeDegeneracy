Cell[BoxData[
 RowBox[{"ContourPlot", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"(", "3.716", ")"}], "==", 
      RowBox[{
       SuperscriptBox["M", 
        RowBox[{
         RowBox[{"-", "1"}], "/", "5"}]], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"m", " ", 
          RowBox[{"(", 
           RowBox[{"M", "-", "m"}], ")"}]}], ")"}], 
        RowBox[{"3", "/", "5"}]]}]}], ",", 
     RowBox[{
      RowBox[{"(", "3.716", ")"}], "==", 
      RowBox[{
       SuperscriptBox["M", 
        RowBox[{
         RowBox[{"-", "1"}], "/", "5"}]], 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{"m", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"m", "-", 
              RowBox[{"(", 
               RowBox[{"M", "-", 
                RowBox[{"2", "m"}]}], ")"}]}], ")"}], "2"]}], 
