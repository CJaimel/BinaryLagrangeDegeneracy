Cell[TextData[{
 "Since the Lagrange three-body system has a phase shift due to the masses, \
there waveform of the Lagrange three-body system will be identical to that of \
the binary system if and only if the phase shifts of the quadrupole and \
0.5-PN waveforms are all the same. This will happen when ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Beta]", "1"], "\[LongEqual]", 
         SubscriptBox["\[Beta]", "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta_1 = \\beta_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "9b6258e6-1145-4c2b-9ed3-05b1609a4bda"],
 ". In this case, the function ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         StyleBox["F", "TI"], "(", 
         RowBox[{
           SubscriptBox["\[Beta]", "1"], ",", 
           SubscriptBox["\[Beta]", "2"]}], ")"}], TraditionalForm], 
     "errors" -> {}, "input" -> "F(\\beta_1, \\beta_2)", "state" -> "Boxes"|>,
    
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "2c221af8-136c-4d80-8bfe-78c275f78da8"],
 " reduces to"
}], "Text",
 CellChangeTimes->{{3.9693070506107817`*^9, 
  3.9693071654748*^9}},ExpressionUUID->"fabe93d5-8ab5-43a9-bff3-5fcc033da1d6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"FullSimplify", "[", 
  RowBox[{
   RowBox[{"F", "[", 
    RowBox[{"\[Alpha]", ",", "\[Alpha]"}], "]"}], ",", 
   RowBox[{"Assumptions", "->", 
    RowBox[{"0", "<", "\[Alpha]", "<", "1"}]}]}], "]"}]], "Input",
 CellChangeTimes->{{3.969307167129396*^9, 3.969307209681059*^9}},
 CellLabel->
  "In[124]:=",ExpressionUUID->"8dcb7f44-0fdf-4900-84bf-64798f00d37a"],

Cell[BoxData[
 FractionBox[
  RowBox[{"2", " ", 
   RowBox[{"Abs", "[", 
    RowBox[{"1", "-", 
     RowBox[{"3", " ", "\[Alpha]"}]}], "]"}]}], 
  RowBox[{"3", " ", "\[Alpha]"}]]], "Output",
 CellChangeTimes->{{3.9693071782464533`*^9, 3.9693072112980957`*^9}, 
   3.969307263764421*^9, 3.9693078390719423`*^9, 3.969479810774248*^9, 
   3.9701979670098886`*^9, 3.970465117732133*^9, 3.970602690093453*^9, 
   3.97165606822047*^9, 3.972529468985354*^9, 3.972853933003826*^9, 
   3.973483902949794*^9, 3.974066145291152*^9, 3.97531711486861*^9, 
   3.975447712983687*^9, 3.980055570053803*^9, 3.981053579412663*^9, 
   3.981401893469668*^9, 3.9815950260370893`*^9},
 CellLabel->
  "Out[124]=",ExpressionUUID->"a83d9f2a-d644-41f1-972a-dc9def2b9c65"]
}, Open  ]],

Cell[TextData[{
 "Next, we consider the case where the chirp masses of the two systems are \
the same. Together with the condition that ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       RowBox[{
         SubscriptBox["\[Beta]", "1"], "\[LongEqual]", 
         SubscriptBox["\[Beta]", "2"]}], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta_1 = \\beta_2", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "b0baf63d-fcd1-466f-b9fd-8e7294b45590"],
 ", equality of the chirp mass means that the mass ratio ",
 Cell[BoxData[
  FormBox[
   TemplateBox[<|"boxes" -> FormBox[
       SubscriptBox["\[Beta]", "1"], TraditionalForm], "errors" -> {}, 
     "input" -> "\\beta_1", "state" -> "Boxes"|>,
    "TeXAssistantTemplate"], TraditionalForm]],ExpressionUUID->
  "5920ad3a-b593-4d12-aa58-0157b33e5a19"],
 " must satisfy"
}], "Text",
 CellChangeTimes->{{3.9704652212806273`*^9, 
  3.97046527150065*^9}},ExpressionUUID->"351e9998-926c-40b1-9a4a-\
088daef0d1cd"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{
    SubscriptBox["M", "chirp"], "[", 
    RowBox[{
     SubscriptBox["\[Beta]", "1"], ",", 
     SubscriptBox["\[Beta]", "1"], ",", 
     SubscriptBox["\[Beta]", "3"]}], "]"}], "/.", 
   RowBox[{
    SubscriptBox["\[Beta]", "3"], "->", 
    RowBox[{"1", "-", 
     RowBox[{"2", 
      SubscriptBox["\[Beta]", "1"]}]}]}]}], "//", "FullSimplify"}]], "Input",
 CellChangeTimes->{{3.975317237087554*^9, 3.975317291709642*^9}, {
  3.97531734486344*^9, 3.975317359403592*^9}},
 CellLabel->
  "In[125]:=",ExpressionUUID->"574f1fc0-8f83-4f1d-9244-79ceb2770111"],

Cell[BoxData[
 SuperscriptBox[
  RowBox[{"(", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"1", "-", 
         RowBox[{"3", " ", 
          SubscriptBox["\[Beta]", "1"]}]}], ")"}], "2"], " ", 
      SubscriptBox["\[Beta]", "1"]}], 
     RowBox[{
      RowBox[{"-", "2"}], "+", 
      RowBox[{"3", " ", 
       SubscriptBox["\[Beta]", "1"]}]}]]}], ")"}], 
  RowBox[{"3", "/", "5"}]]], "Output",
 CellChangeTimes->{{3.9753172866524773`*^9, 3.975317293358152*^9}, 
   3.975317360529622*^9, 3.9754477130021477`*^9, 3.980055570072027*^9, 
   3.9810535794248466`*^9, 3.9814018934818993`*^9, 3.981595026051235*^9},
 CellLabel->
  "Out[125]=",ExpressionUUID->"e63376b0-5810-4ca9-b979-87e694e58a6e"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sols", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"a", "==", 
       SuperscriptBox[
        RowBox[{"(", 
         FractionBox[
          RowBox[{
           SubscriptBox["\[Beta]", "1"], 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{
              RowBox[{"3", 
               SubscriptBox["\[Beta]", "1"]}], "-", "1"}], ")"}], "2"]}], 
          RowBox[{"2", "-", 
           RowBox[{"3", 
            SubscriptBox["\[Beta]", "1"]}]}]], ")"}], 
        RowBox[{"3", "/", "5"}]]}], ",", 
      RowBox[{
       SubscriptBox["\[Beta]", "1"], ">", "0"}], ",", 
      RowBox[{"a", ">", "0"}]}], "}"}], ",", 
    SubscriptBox["\[Beta]", "1"], ",", "Reals"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.970198442887961*^9, 3.970198560532592*^9}, {
