Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "mass", " ", "quadrupole", " ", "without", " ", "radiation", " ", 
    "reaction"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["h", "quadplus"], "[", 
      RowBox[{
      "l_", ",", "\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_", ",", "r_", 
       ",", "\[Iota]_", ",", "t_", ",", "\[Phi]_"}], "]"}], ":=", 
     RowBox[{
      FractionBox[
       RowBox[{"-", "2"}], "r"], 
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
       RowBox[{"5", "/", "6"}]], 
      SuperscriptBox[
       RowBox[{
        SubscriptBox["M", "chirp"], "[", 
        RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "]"}], 
       RowBox[{"5", "/", "6"}]], 
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox[
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
          RowBox[{"1", "/", "2"}]], 
         SuperscriptBox["l", 
          RowBox[{"3", "/", "2"}]]], ")"}], 
       RowBox[{"2", "/", "3"}]], 
      RowBox[{"(", 
       RowBox[{"1", "+", 
        SuperscriptBox[
         RowBox[{"Cos", "[", "\[Iota]", "]"}], "2"]}], ")"}], 
      FractionBox[
       SqrtBox[
        RowBox[{
         RowBox[{"\[Alpha]", " ", "\[Beta]"}], "+", 
         RowBox[{"\[Beta]", " ", "\[Gamma]"}], " ", "+", 
         RowBox[{"\[Gamma]", " ", "\[Alpha]"}]}]], 
       RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}]], 
      RowBox[{"Cos", "[", 
       RowBox[{
        RowBox[{"2", 
         RowBox[{"(", 
          FractionBox[
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
            RowBox[{"1", "/", "2"}]], 
           SuperscriptBox["l", 
            RowBox[{"3", "/", "2"}]]], ")"}], " ", "t"}], "-", 
        RowBox[{
         SubscriptBox["\[CapitalPsi]", "quad"], "[", 
         RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "]"}], "-", 
        "\[Phi]"}], "]"}]}]}], ";"}], " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["h", "quadcross"], "[", 
      RowBox[{
      "l_", ",", "\[Alpha]_", ",", "\[Beta]_", ",", "\[Gamma]_", ",", "r_", 
