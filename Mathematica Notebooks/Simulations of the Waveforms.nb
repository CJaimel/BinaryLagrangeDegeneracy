Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"ConditionalExpression", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"ArcSin", "[", 
       SqrtBox[
        RowBox[{"2", "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            FractionBox["1", "4"], "-", 
            RowBox[{
             FractionBox["9", "2"], 
             RowBox[{"(", 
              FractionBox["5", "9"], ")"}], 
             FractionBox["1", 
              SqrtBox[
               FractionBox[
                RowBox[{
                 RowBox[{"3", " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    SubscriptBox["\[Beta]", "1"], "+", 
                    SubscriptBox["\[Beta]", "2"]}], ")"}], "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"2", " ", 
                    SubsuperscriptBox["\[Beta]", "1", "2"]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "1"], " ", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}]}]}], ")"}], 
                   "2"]}], "+", 
                 SuperscriptBox[
                  RowBox[{"(", 
                   RowBox[{
                    SubscriptBox["\[Beta]", "1"], "-", 
                    RowBox[{"3", " ", 
                    SubsuperscriptBox["\[Beta]", "1", "2"]}], "+", 
                    RowBox[{"2", " ", 
                    SubsuperscriptBox["\[Beta]", "1", "3"]}], "+", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "2"], " ", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{
                    RowBox[{"(", 
                    RowBox[{"3", "-", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}], " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}]}]}], ")"}], 
                  "2"]}], 
                RowBox[{
                 RowBox[{"27", " ", 
                  SubsuperscriptBox["\[Beta]", "1", "2"], " ", 
                  SubsuperscriptBox["\[Beta]", "2", "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    SubscriptBox["\[Beta]", "1"], "+", 
                    SubscriptBox["\[Beta]", "2"]}], ")"}], "2"]}], "+", 
                 RowBox[{
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    SubscriptBox["\[Beta]", "1"], "-", 
                    SubscriptBox["\[Beta]", "2"]}], ")"}], "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "1"]}], "+", 
                    SubscriptBox["\[Beta]", "2"]}], ")"}], "2"], " ", 
                  SuperscriptBox[
                   RowBox[{"(", 
                    RowBox[{
                    RowBox[{"-", "1"}], "+", 
                    SubscriptBox["\[Beta]", "1"], "+", 
                    RowBox[{"2", " ", 
                    SubscriptBox["\[Beta]", "2"]}]}], ")"}], "2"]}]}]]]]}]}], 
           ")"}], 
          RowBox[{"-", "1"}]]}]], "]"}], "\[Times]", 
      FractionBox["180", "\[Pi]"]}], ",", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["\[Beta]", "1"], "+", 
        SubscriptBox["\[Beta]", "2"]}], "<=", "1"}], "&&", 
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["\[Beta]", "1"], 
         SubscriptBox["\[Beta]", "2"]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           SubscriptBox["\[Beta]", "1"], "+", 
           SubscriptBox["\[Beta]", "2"]}], ")"}], 
         RowBox[{"(", 
          RowBox[{"1", "-", 
           SubscriptBox["\[Beta]", "1"], "-", 
           SubscriptBox["\[Beta]", "2"]}], ")"}]}]}], "<=", 
       FractionBox["1", "27"]}]}]}], "]"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Beta]", "1"], ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     SubscriptBox["\[Beta]", "2"], ",", "0", ",", "1"}], "}"}], ",", 
   RowBox[{"AxesLabel", "->", 
    RowBox[{"{", 
     RowBox[{
     "\"\<\!\(\*SubscriptBox[\(\[Beta]\), \(1\)]\)\>\"", ",", 
      "\"\<\!\(\*SubscriptBox[\(\[Beta]\), \(2\)]\)\>\"", ",", 
      "\"\<\!\(\*SubscriptBox[\(\[Iota]\), \((3  B)\)]\)\>\""}], "}"}]}]}], 
