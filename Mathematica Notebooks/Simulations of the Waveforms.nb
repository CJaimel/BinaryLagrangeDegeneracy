         RowBox[{"\[Gamma]", " ", "\[Alpha]"}]}]], 
       RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}]], 
      RowBox[{"Sin", "[", 
       RowBox[{
        RowBox[{"2", 
         FractionBox[
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
