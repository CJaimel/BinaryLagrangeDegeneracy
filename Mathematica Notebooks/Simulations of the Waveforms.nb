          RowBox[{"3", "\[Phi]"}]}], "]"}]}], "-", 
       RowBox[{
        FractionBox["1", "2"], 
        RowBox[{"(", 
         RowBox[{"5", "+", 
          SuperscriptBox[
           RowBox[{"Cos", "[", "\[Iota]", "]"}], "2"]}], ")"}], 
        FractionBox[
         SqrtBox[
          RowBox[{
           RowBox[{"3", 
            SuperscriptBox["\[Alpha]", "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{"\[Beta]", 
                RowBox[{"(", 
                 RowBox[{"\[Beta]", "-", "\[Alpha]"}], ")"}]}], "+", 
               RowBox[{"\[Gamma]", 
                RowBox[{"(", 
                 RowBox[{"\[Gamma]", "-", "\[Alpha]"}], ")"}]}]}], ")"}], 
             "2"]}], "+", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"\[Beta]", "-", "\[Gamma]"}], ")"}], "2"], 
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"\[Alpha]", "-", "\[Beta]"}], ")"}], 
                RowBox[{"(", 
                 RowBox[{"\[Alpha]", "-", "\[Gamma]"}], ")"}]}], "-", 
               RowBox[{"3", "\[Beta]", " ", "\[Gamma]"}]}], ")"}], "2"]}]}]], 
         
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
          "3"]], 
        RowBox[{"Cos", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            FractionBox[
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"\[Alpha]", "+", "\[Beta]", "+", "\[Gamma]"}], ")"}], 
              RowBox[{"1", "/", "2"}]], 
             SuperscriptBox["l", 
              RowBox[{"3", "/", "2"}]]], ")"}], "t"}], "-", 
          RowBox[{
           SubscriptBox["\[CapitalPsi]", "1"], "[", 
           RowBox[{"\[Alpha]", ",", "\[Beta]", ",", "\[Gamma]"}], "]"}], "-", 
          "\[Phi]"}], "]"}]}]}], ")"}]}]}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SubscriptBox["h", "octcqCross"], "[", 
