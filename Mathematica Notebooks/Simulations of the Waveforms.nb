Cell[BoxData[
 RowBox[{"Plot3D", "[", 
  RowBox[{
   RowBox[{"ConditionalExpression", "[", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        FractionBox["M", "7.776774233174123"], ")"}], 
       RowBox[{"5", "/", "3"}]], 
      RowBox[{"(", 
       RowBox[{"2", "\[Times]", 
